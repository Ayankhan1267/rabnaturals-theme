{% if settings.show_announcement %}
<div class="announcement-bar" role="region" aria-label="Announcement">
  <div class="announcement-bar__wrapper page-width">
    <button class="announcement-bar__arrow announcement-bar__arrow--left" aria-label="Previous announcement">
      {% render 'icon', name: 'chevron-left', size: 14 %}
    </button>
    <div class="announcement-bar__slider" data-announcement-slider>
      {% if settings.announcement_text_1 != blank %}
        <div class="announcement-bar__slide active">{{ settings.announcement_text_1 }}</div>
      {% endif %}
      {% if settings.announcement_text_2 != blank %}
        <div class="announcement-bar__slide">{{ settings.announcement_text_2 }}</div>
      {% endif %}
      {% if settings.announcement_text_3 != blank %}
        <div class="announcement-bar__slide">{{ settings.announcement_text_3 }}</div>
      {% endif %}
      {% if settings.announcement_text_4 != blank %}
        <div class="announcement-bar__slide">{{ settings.announcement_text_4 }}</div>
      {% endif %}
      {% if settings.announcement_text_5 != blank %}
        <div class="announcement-bar__slide">{{ settings.announcement_text_5 }}</div>
      {% endif %}
    </div>
    <button class="announcement-bar__arrow announcement-bar__arrow--right" aria-label="Next announcement">
      {% render 'icon', name: 'chevron-right', size: 14 %}
    </button>
    <button class="announcement-bar__close" aria-label="Close announcement">
      {% render 'icon', name: 'close', size: 12 %}
    </button>
  </div>
</div>
{% endif %}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [],
  "presets": [
    {
      "name": "Announcement bar"
    }
  ]
}
{% endschema %}
