<nav class="mobile-nav" data-mobile-nav>
  <div class="mobile-nav__overlay" data-mobile-close></div>
  <div class="mobile-nav__drawer">
    <div class="mobile-nav__header">
      {% if settings.logo != blank %}
        <img src="{{ settings.logo | img_url: 'master' }}" alt="{{ shop.name }}" width="80" loading="lazy">
      {% else %}
        <span class="mobile-nav__title">{{ shop.name }}</span>
      {% endif %}
      <button class="mobile-nav__close" aria-label="Close menu" data-mobile-close>
        {% render 'icon', name: 'close', size: 20 %}
      </button>
    </div>
    <ul class="mobile-nav__list">
      {% for link in linklists.main-menu.links %}
        <li class="mobile-nav__item">
          <a href="{{ link.url }}" class="mobile-nav__link">{{ link.title }}</a>
          {% if link.links != blank %}
            <button class="mobile-nav__toggle" aria-label="Toggle submenu" data-sub-toggle>
              {% render 'icon', name: 'chevron-right', size: 16 %}
            </button>
            <ul class="mobile-nav__sublist">
              {% for child in link.links %}
                <li><a href="{{ child.url }}" class="mobile-nav__sublink">{{ child.title }}</a></li>
              {% endfor %}
            </ul>
          {% endif %}
        </li>
      {% endfor %}
    </ul>
    <div class="mobile-nav__footer">
      <a href="/pages/skin-analysis" class="mobile-nav__cta">Know Your Skin</a>
      {% if shop.customer_accounts_enabled %}
        <a href="{% if customer %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}" class="mobile-nav__account">Account</a>
      {% endif %}
    </div>
  </div>
</nav>

<nav class="bottom-nav">
  <a href="{{ routes.root_url }}" class="bottom-nav__item{% if template.name == 'index' %} active{% endif %}">
    {% render 'icon', name: 'home', size: 20 %}
    <span>Home</span>
  </a>
  <a href="/collections/all" class="bottom-nav__item">
    {% render 'icon', name: 'shop', size: 20 %}
    <span>Shop</span>
  </a>
  <a href="/pages/skin-analysis" class="bottom-nav__item bottom-nav__item--cta">
    <span class="bottom-nav__cta-icon">
      {% render 'icon', name: 'leaf', size: 24 %}
    </span>
    <span>Know Your Skin</span>
  </a>
  <a href="/account" class="bottom-nav__item">
    {% render 'icon', name: 'user', size: 20 %}
    <span>Profile</span>
  </a>
</nav>

{% schema %}
{
  "name": "Mobile nav",
  "settings": [],
  "presets": [
    {
      "name": "Mobile nav"
    }
  ]
}
{% endschema %}
