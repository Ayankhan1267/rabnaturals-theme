<section class="bestsellers">
  <div class="page-width">
    <h2 class="section-title section-title--center">{{ section.settings.heading | default: "Bestsellers" }}</h2>
    <div class="bestsellers__tabs" data-tabs>
      {% for block in section.blocks %}
        <button class="bestsellers__tab{% if forloop.first %} active{% endif %}" data-tab="{{ forloop.index0 }}">{{ block.settings.title }}</button>
      {% endfor %}
    </div>
    <div class="bestsellers__panels">
      {% for block in section.blocks %}
        <div class="bestsellers__panel{% if forloop.first %} active{% endif %}" data-panel="{{ forloop.index0 }}">
          <div class="bestsellers__grid" data-carousel>
            {% assign collection_handle = block.settings.collection %}
            {% if collection_handle != blank %}
              {% assign collection = collections[collection_handle] %}
              {% for product in collection.products limit: 10 %}
                {% render 'product-card' product: product %}
              {% endfor %}
            {% else %}
              {% for i in (1..4) %}
                <div class="product-card product-card--placeholder">
                  <div class="product-card__image-wrap">
                    {{ 'product-' | append: i | placeholder_svg_tag: 'product-card__placeholder-svg' }}
                  </div>
                  <div class="product-card__info">
                    <h3 class="product-card__title">Product {{ i }}</h3>
                    <div class="product-card__price">
                      <span class="product-card__price--current">Rs. 499</span>
                    </div>
                  </div>
                </div>
              {% endfor %}
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bestsellers",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Bestsellers"
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Tab",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Tab title",
          "default": "Trending"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Bestsellers",
      "category": "Home",
      "blocks": [
        { "type": "tab", "settings": { "title": "Trending" } },
        { "type": "tab", "settings": { "title": "Cleanser" } },
        { "type": "tab", "settings": { "title": "Serum" } },
        { "type": "tab", "settings": { "title": "Moisturizer" } }
      ]
    }
  ]
}
{% endschema %}
