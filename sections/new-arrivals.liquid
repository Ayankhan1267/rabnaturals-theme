<section class="new-arrivals">
  <div class="page-width">
    <div class="new-arrivals__header">
      <h2 class="section-title">{{ section.settings.heading | default: "New Arrivals" }}</h2>
      <a href="{{ section.settings.view_all_link | default: '/collections/all' }}" class="new-arrivals__view-all">View All</a>
    </div>
    <div class="new-arrivals__grid" data-carousel>
      {% assign collection_handle = section.settings.collection %}
      {% if collection_handle != blank %}
        {% assign collection = collections[collection_handle] %}
        {% for product in collection.products limit: section.settings.limit %}
          {% render 'product-card' product: product %}
        {% endfor %}
      {% else %}
        {% for i in (1..4) %}
          <div class="product-card product-card--placeholder">
            <div class="product-card__image-wrap">
              {{ 'product-' | append: i | placeholder_svg_tag: 'product-card__placeholder-svg' }}
            </div>
            <div class="product-card__info">
              <h3 class="product-card__title">New Product {{ i }}</h3>
              <div class="product-card__price">
                <span class="product-card__price--current">Rs. 599</span>
              </div>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "New arrivals",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "New Arrivals"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "limit",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 8
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View all link"
    }
  ],
  "presets": [
    {
      "name": "New arrivals",
      "category": "Home"
    }
  ]
}
{% endschema %}
