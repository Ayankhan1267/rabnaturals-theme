<section class="shop-by-concern">
  <div class="page-width">
    <h2 class="section-title section-title--center">{{ section.settings.heading | default: "Targeted Solutions" }}</h2>
    <p class="section-desc">{{ section.settings.description | default: "Shop by Skin Concern" }}</p>
    <div class="shop-by-concern__grid">
      {% for block in section.blocks %}
        <div class="shop-by-concern__card" {{ block.shopify_attributes }}>
          <a href="{{ block.settings.link | default: '/collections/all' }}" class="shop-by-concern__link">
            {% if block.settings.image != blank %}
              <img src="{{ block.settings.image | img_url: '300x300', crop: 'center' }}" alt="{{ block.settings.title }}" loading="lazy" class="shop-by-concern__image">
            {% else %}
              {% assign concern_icons = "🔴|⏳|💧|⚫|☀️|〰️" | split: "|" %}
              {% assign cidx = forloop.index0 | modulo: 6 %}
              <div class="shop-by-concern__placeholder">{{ concern_icons[cidx] }}</div>
            {% endif %}
            <span class="shop-by-concern__title">{{ block.settings.title }}</span>
          </a>
        </div>
      {% endfor %}
    </div>
    <div class="shop-by-concern__cta">
      <a href="{{ section.settings.view_all_link | default: '/collections/all' }}" class="btn btn--outline">Explore All Products</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Shop by concern",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Targeted Solutions"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "Shop by Skin Concern"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View all link"
    }
  ],
  "blocks": [
    {
      "type": "concern",
      "name": "Skin concern",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Acne"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Shop by concern",
      "category": "Home",
      "blocks": [
        { "type": "concern", "settings": { "title": "Acne" } },
        { "type": "concern", "settings": { "title": "Anti-Aging" } },
        { "type": "concern", "settings": { "title": "Dryness" } },
        { "type": "concern", "settings": { "title": "Dark Spots" } },
        { "type": "concern", "settings": { "title": "Sun Protection" } },
        { "type": "concern", "settings": { "title": "Wrinkles" } }
      ]
    }
  ]
}
{% endschema %}
