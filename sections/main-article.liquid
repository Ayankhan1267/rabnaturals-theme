<article class="main-article">
  <div class="page-width">
    <div class="main-article__breadcrumb">
      <a href="{{ blog.url }}">{{ blog.title }}</a>
      <span>/</span>
      <span>{{ article.title }}</span>
    </div>
    <h1 class="main-article__title">{{ article.title }}</h1>
    <div class="main-article__meta">
      <span>{{ article.author }}</span>
      <span>{{ article.published_at | date: '%B %d, %Y' }}</span>
    </div>
    {% if article.image %}
      <div class="main-article__image">
        <img src="{{ article.image | img_url: '1200x600', crop: 'center' }}" alt="{{ article.title }}" loading="lazy">
      </div>
    {% endif %}
    <div class="main-article__content rte">
      {{ article.content }}
    </div>
  </div>
</article>

{% schema %}
{
  "name": "Main article",
  "settings": [],
  "presets": [
    {
      "name": "Main article"
    }
  ]
}
{% endschema %}
