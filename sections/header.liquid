<header class="header" data-header>
  <div class="header__bg"></div>
  <div class="header__wrapper page-width">
    <div class="header__left">
      <button class="header__mobile-toggle" aria-label="Menu" data-mobile-toggle>
        <span class="header__hamburger">
          <span></span><span></span><span></span>
        </span>
      </button>
      <a href="{{ routes.root_url }}" class="header__logo">
        <img src="{{ 'logo.png' | asset_url }}" alt="{{ shop.name }}" width="140" height="auto" loading="eager" class="header__logo-img">
      </a>
    </div>

    <nav class="header__nav" data-header-nav>
      <ul class="header__nav-list">
        {% for link in linklists.main-menu.links %}
          <li class="header__nav-item {% if link.links != blank %}header__nav-item--has-dropdown{% endif %}">
            <a href="{{ link.url }}" class="header__nav-link">
              {{ link.title }}
              {% if link.links != blank %}
                <svg class="header__nav-arrow" width="10" height="6" viewBox="0 0 10 6" fill="none">
                  <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              {% endif %}
            </a>
            {% if link.links != blank %}
              <div class="header__dropdown">
                <div class="header__dropdown-shine"></div>
                <ul class="header__dropdown-list">
                  {% for child in link.links %}
                    <li>
                      <a href="{{ child.url }}" class="header__dropdown-link">{{ child.title }}</a>
                    </li>
                  {% endfor %}
                </ul>
              </div>
            {% endif %}
          </li>
        {% endfor %}
      </ul>
    </nav>

    <div class="header__right">
      <button class="header__icon header__search-btn" aria-label="Search" data-search-open>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/>
          <path d="M21 21L16.65 16.65"/>
        </svg>
      </button>
      <a href="/pages/skin-analysis" class="header__icon header__skin-btn header__icon--desktop">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 20h9"/>
          <path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/>
        </svg>
        <span>Know Your Skin</span>
      </a>
      <a href="/cart" class="header__icon header__cart-btn" aria-label="Cart">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 01-8 0"/>
        </svg>
        <span class="header__cart-count" data-cart-count>{{ cart.item_count }}</span>
      </a>
      {% if shop.customer_accounts_enabled %}
        <a href="{% if customer %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}" class="header__icon header__account-btn header__icon--desktop" aria-label="Account">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
        </a>
      {% endif %}
    </div>
  </div>

  <div class="search-overlay" data-search-overlay>
    <div class="search-overlay__content">
      <div class="search-overlay__header">
        <form action="{{ routes.search_url }}" method="get" role="search" class="search-overlay__form">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/>
            <path d="M21 21L16.65 16.65"/>
          </svg>
          <input type="search" name="q" placeholder="Search products..." class="search-overlay__input" autocomplete="off" data-search-input>
          <button type="button" class="search-overlay__close" data-search-close>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="18" y1="6" x2="6" y2="18"/>
              <line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
          </button>
        </form>
      </div>
      <div class="search-overlay__results" data-search-results>
        <p class="search-overlay__placeholder">Search for products, categories...</p>
      </div>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [],
  "presets": [
    {
      "name": "Header"
    }
  ]
}
{% endschema %}
