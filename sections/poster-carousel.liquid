<section class="poster-carousel">
  <div class="poster-carousel__wrapper" data-poster-carousel>
    {% for block in section.blocks %}
      {% assign bg_colors = "linear-gradient(135deg, #0197a6, #017d89)|linear-gradient(135deg, #8b5cf6, #6d28d9)|linear-gradient(135deg, #f59e0b, #d97706)|linear-gradient(135deg, #f43f5e, #e11d48)|linear-gradient(135deg, #0ea5e9, #0284c7)" | split: "|" %}
      {% assign idx = forloop.index0 | modulo: 5 %}
      <div class="poster-carousel__slide{% if forloop.first %} active{% endif %}" data-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
        <a href="{{ block.settings.link | default: '/collections/all' }}" class="poster-carousel__link">
          {% if block.settings.image_desktop != blank %}
            <img src="{{ block.settings.image_desktop | img_url: '1920x' }}" alt="{{ block.settings.alt }}" loading="lazy" class="poster-carousel__image poster-carousel__image--desktop">
          {% else %}
            <div class="poster-carousel__placeholder poster-carousel__placeholder--desktop" style="background: {{ bg_colors[idx] }};">
              <div class="poster-carousel__placeholder-content">
                <span class="poster-carousel__placeholder-icon">
                  {% render 'icon', name: 'image', size: 48 %}
                </span>
                <h3 class="poster-carousel__placeholder-title">{{ block.settings.alt | default: "Banner Image" }}</h3>
                <p class="poster-carousel__placeholder-sub">Upload from theme settings</p>
              </div>
            </div>
          {% endif %}
          {% if block.settings.image_mobile != blank %}
            <img src="{{ block.settings.image_mobile | img_url: '800x' }}" alt="{{ block.settings.alt }}" loading="lazy" class="poster-carousel__image poster-carousel__image--mobile">
          {% elsif block.settings.image_desktop != blank %}
            <img src="{{ block.settings.image_desktop | img_url: '800x' }}" alt="{{ block.settings.alt }}" loading="lazy" class="poster-carousel__image poster-carousel__image--mobile">
          {% else %}
            <div class="poster-carousel__placeholder poster-carousel__placeholder--mobile" style="background: {{ bg_colors[idx] }};">
              <div class="poster-carousel__placeholder-content">
                <span class="poster-carousel__placeholder-icon">
                  {% render 'icon', name: 'image', size: 36 %}
                </span>
                <span class="poster-carousel__placeholder-title">{{ block.settings.alt | default: "Banner" }}</span>
              </div>
            </div>
          {% endif %}
        </a>
      </div>
    {% endfor %}
  </div>
  {% if section.blocks.size > 1 %}
    <div class="poster-carousel__controls">
      <button class="poster-carousel__arrow poster-carousel__arrow--left" aria-label="Previous" data-poster-prev>
        {% render 'icon', name: 'chevron-left', size: 20 %}
      </button>
      <div class="poster-carousel__dots">
        {% for block in section.blocks %}
          <span class="poster-carousel__dot{% if forloop.first %} active{% endif %}" data-index="{{ forloop.index0 }}"></span>
        {% endfor %}
      </div>
      <button class="poster-carousel__arrow poster-carousel__arrow--right" aria-label="Next" data-poster-next>
        {% render 'icon', name: 'chevron-right', size: 20 %}
      </button>
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Poster carousel",
  "settings": [],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image_desktop",
          "label": "Desktop image (1920px)"
        },
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "Mobile image (800px)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Alt text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Poster carousel",
      "category": "Home"
    }
  ]
}
{% endschema %}
