<section class="testimonials">
  <div class="page-width">
    <h2 class="section-title section-title--center">{{ section.settings.heading | default: "What Our Customers Say" }}</h2>
    <p class="section-desc section-desc--center">4.8/5 from 50,000+ customers</p>
    <div class="testimonials__wrapper">
      <button class="testimonials__arrow testimonials__arrow--left" aria-label="Previous" data-testimonial-prev>
        {% render 'icon', name: 'chevron-left', size: 20 %}
      </button>
      <div class="testimonials__track" data-testimonial-track>
        {% for block in section.blocks %}
          <div class="testimonials__card" {{ block.shopify_attributes }}>
            <div class="testimonials__quote">
              {% render 'icon', name: 'quote', size: 20, color: settings.color_primary %}
            </div>
            <p class="testimonials__text">{{ block.settings.review }}</p>
            <div class="testimonials__stars">
              {% assign rating = block.settings.rating | default: 5 %}
              {% for i in (1..rating) %}
                {% render 'icon', name: 'star', size: 16, fill: '#f59e0b' %}
              {% endfor %}
            </div>
            <div class="testimonials__author">
              <span class="testimonials__avatar">{{ block.settings.name | slice: 0 }}</span>
              <div>
                <strong>{{ block.settings.name }}</strong>
                <span>{{ block.settings.location }}</span>
              </div>
              {% if block.settings.verified %}
                {% render 'icon', name: 'verified', size: 16, color: '#0197a6' %}
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
      <button class="testimonials__arrow testimonials__arrow--right" aria-label="Next" data-testimonial-next>
        {% render 'icon', name: 'chevron-right', size: 20 %}
      </button>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Our Customers Say"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "textarea",
          "id": "review",
          "label": "Review text",
          "default": "Amazing products! My skin has never felt this good."
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Priya S."
        },
        {
          "type": "text",
          "id": "location",
          "label": "Location",
          "default": "Mumbai"
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "checkbox",
          "id": "verified",
          "label": "Verified buyer",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "category": "Home",
      "blocks": [
        { "type": "review", "settings": { "review": "Amazing products! My skin has never felt this good.", "name": "Priya S.", "location": "Mumbai" } },
        { "type": "review", "settings": { "review": "The AI skin analysis was eye-opening. Found the perfect routine!", "name": "Ananya K.", "location": "Delhi" } },
        { "type": "review", "settings": { "review": "Finally a brand that understands Indian skin. Love the natural ingredients.", "name": "Rahul M.", "location": "Bangalore" } }
      ]
    }
  ]
}
{% endschema %}
