<section class="testimonials">
  <div class="page-width">
    <h2 class="section-title section-title--center">{{ section.settings.heading | default: "What Our Customers Say" }}</h2>
    <p class="section-desc section-desc--center">4.8/5 from 50,000+ customers</p>
    <div class="testimonials__wrapper">
      <button class="testimonials__arrow testimonials__arrow--left" aria-label="Previous" data-testimonial-prev>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg>
      </button>
      <div class="testimonials__track" data-testimonial-track>
        {% for block in section.blocks %}
          <div class="testimonials__card" {{ block.shopify_attributes }}>
            <div class="testimonials__quote">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="{{ settings.color_primary }}"><path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1z"></path><path d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z"></path></svg>
            </div>
            <p class="testimonials__text">{{ block.settings.review }}</p>
            <div class="testimonials__stars">
              {% assign rating = block.settings.rating | default: 5 %}
              {% for i in (1..rating) %}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
              {% endfor %}
            </div>
            <div class="testimonials__author">
              <span class="testimonials__avatar">{{ block.settings.name | slice: 0 }}</span>
              <div>
                <strong>{{ block.settings.name }}</strong>
                <span>{{ block.settings.location }}</span>
              </div>
              {% if block.settings.verified %}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="#0197a6"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
      <button class="testimonials__arrow testimonials__arrow--right" aria-label="Next" data-testimonial-next>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </button>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Our Customers Say"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "textarea",
          "id": "review",
          "label": "Review text",
          "default": "Amazing products! My skin has never felt this good."
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Priya S."
        },
        {
          "type": "text",
          "id": "location",
          "label": "Location",
          "default": "Mumbai"
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "checkbox",
          "id": "verified",
          "label": "Verified buyer",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "category": "Home",
      "blocks": [
        { "type": "review", "settings": { "review": "Amazing products! My skin has never felt this good.", "name": "Priya S.", "location": "Mumbai" } },
        { "type": "review", "settings": { "review": "The AI skin analysis was eye-opening. Found the perfect routine!", "name": "Ananya K.", "location": "Delhi" } },
        { "type": "review", "settings": { "review": "Finally a brand that understands Indian skin. Love the natural ingredients.", "name": "Rahul M.", "location": "Bangalore" } }
      ]
    }
  ]
}
{% endschema %}
