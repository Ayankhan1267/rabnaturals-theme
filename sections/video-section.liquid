<section class="video-section">
  <div class="page-width">
    <h2 class="section-title section-title--center" style="color: white;">{{ section.settings.heading | default: "Watch it. Love it." }}</h2>
    <div class="video-section__grid">
      {% for block in section.blocks %}
        <div class="video-section__card" {{ block.shopify_attributes }}>
          <div class="video-section__thumbnail" data-video-trigger="{{ block.settings.video_url }}">
            {% if block.settings.thumbnail != blank %}
              <img src="{{ block.settings.thumbnail | img_url: '600x' }}" alt="{{ block.settings.title }}" loading="lazy">
            {% else %}
              <div class="video-section__placeholder">
                {% render 'icon', name: 'play', size: 60 %}
              </div>
            {% endif %}
            <div class="video-section__play">
              {% render 'icon', name: 'play', size: 48 %}
            </div>
          </div>
          <div class="video-section__info">
            <h3 class="video-section__product-name">{{ block.settings.title }}</h3>
            <span class="video-section__price">{{ block.settings.price }}</span>
            <button class="btn btn--primary btn--full video-section__atc" data-add-to-cart="{{ block.settings.variant_id }}">
              Add to Cart
            </button>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>

  <div class="video-section__modal" data-video-modal>
    <div class="video-section__modal-overlay" data-video-close></div>
    <div class="video-section__modal-content">
      <button class="video-section__modal-close" data-video-close>
        {% render 'icon', name: 'close', size: 24 %}
      </button>
      <div class="video-section__modal-player" data-video-player>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Video section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Watch it. Love it."
    }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Video",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Product name"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price",
          "default": "Rs. 499"
        },
        {
          "type": "text",
          "id": "variant_id",
          "label": "Variant ID"
        },
        {
          "type": "url",
          "id": "video_url",
          "label": "Video URL (YouTube/Shopify)"
        },
        {
          "type": "image_picker",
          "id": "thumbnail",
          "label": "Thumbnail"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Video section",
      "category": "Home"
    }
  ]
}
{% endschema %}
