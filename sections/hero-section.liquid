<section class="hero">
  <div class="hero__bg">
    <div class="hero__blob hero__blob--1"></div>
    <div class="hero__blob hero__blob--2"></div>
  </div>
  <div class="page-width">
    <div class="hero__grid">
      <div class="hero__content">
        <span class="hero__tag">Ancient Wisdom · Modern Science</span>
        <h1 class="hero__title">{{ section.settings.heading | default: "Skincare Rooted in<br>Indian Tradition" }}</h1>
        <p class="hero__desc">{{ section.settings.description | default: "Harnessing the power of masoor, moong, chana, oats and traditional Indian grains — skincare your dadi would approve of." }}</p>
        <div class="hero__actions">
          <a href="{{ section.settings.cta_link | default: '/collections/all' }}" class="btn btn--primary">{{ section.settings.cta_text | default: "Shop Now" }}</a>
          <a href="{{ section.settings.cta_secondary_link | default: '/pages/skin-analysis' }}" class="btn btn--outline">{{ section.settings.cta_secondary_text | default: "Free AI Skin Analysis" }}</a>
        </div>
        <div class="hero__trust">
          <span>50,000+ Customers</span>
          <span>4.8★ Rating</span>
          <span>100% Natural</span>
        </div>
        <div class="hero__ingredients">
          <span class="hero__pill">Masoor Dal</span>
          <span class="hero__pill">Moong Dal</span>
          <span class="hero__pill">Oats</span>
          <span class="hero__pill">Rice</span>
          <span class="hero__pill">Chana Dal</span>
          <span class="hero__pill">Urad Dal</span>
        </div>
      </div>
      <div class="hero__visual">
        <div class="hero__circle">
          <div class="hero__circle-inner">
            <span class="hero__circle-text">🌿</span>
          </div>
          <div class="hero__float hero__float--1">Masoor Dal</div>
          <div class="hero__float hero__float--2">Moong Dal</div>
          <div class="hero__float hero__float--3">Oats</div>
          <div class="hero__float hero__float--4">Rice</div>
          <div class="hero__float hero__float--5">Chana Dal</div>
          <div class="hero__float hero__float--6">Urad Dal</div>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Skincare Rooted in<br>Indian Tradition"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Harnessing the power of masoor, moong, chana, oats and traditional Indian grains"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Primary CTA text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Primary CTA link"
    },
    {
      "type": "text",
      "id": "cta_secondary_text",
      "label": "Secondary CTA text",
      "default": "Free AI Skin Analysis"
    },
    {
      "type": "url",
      "id": "cta_secondary_link",
      "label": "Secondary CTA link"
    }
  ],
  "presets": [
    {
      "name": "Hero section",
      "category": "Home"
    }
  ]
}
{% endschema %}
