<section class="skin-tracker-banner">
  <div class="page-width">
    <a href="{{ section.settings.link | default: '/pages/skin-checker' }}" class="skin-tracker-banner__link">
      <div class="skin-tracker-banner__content">
        <div class="skin-tracker-banner__text">
          <h2 class="skin-tracker-banner__title">{{ section.settings.heading | default: "Daily Skin Tracker" }}</h2>
          <p class="skin-tracker-banner__desc">{{ section.settings.description | default: "Track your skin daily with AI-powered analysis" }}</p>
          <ul class="skin-tracker-banner__features">
            <li>Daily photo check-in</li>
            <li>AI analysis</li>
            <li>21-day progress report</li>
          </ul>
          <span class="btn btn--white">{{ section.settings.cta | default: "Start Tracking" }}</span>
        </div>
        <div class="skin-tracker-banner__visual">
          <svg width="200" height="80" viewBox="0 0 200 80" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="10" y="40" width="20" height="30" rx="4" fill="rgba(255,255,255,0.3)"/>
            <rect x="40" y="25" width="20" height="45" rx="4" fill="rgba(255,255,255,0.5)"/>
            <rect x="70" y="35" width="20" height="35" rx="4" fill="white"/>
            <rect x="100" y="15" width="20" height="55" rx="4" fill="rgba(255,255,255,0.7)"/>
            <rect x="130" y="30" width="20" height="40" rx="4" fill="rgba(255,255,255,0.4)"/>
            <rect x="160" y="20" width="20" height="50" rx="4" fill="rgba(255,255,255,0.6)"/>
          </svg>
        </div>
      </div>
    </a>
  </div>
</section>

{% schema %}
{
  "name": "Skin tracker banner",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Daily Skin Tracker"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Track your skin daily with AI-powered analysis"
    },
    {
      "type": "text",
      "id": "cta",
      "label": "CTA text",
      "default": "Start Tracking"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    }
  ],
  "presets": [
    {
      "name": "Skin tracker banner",
      "category": "Home"
    }
  ]
}
{% endschema %}
