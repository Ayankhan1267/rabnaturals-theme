<section class="main-blog">
  <div class="page-width">
    <h1 class="main-blog__title">{{ blog.title }}</h1>
    <div class="main-blog__grid">
      {% for article in blog.articles %}
        <article class="main-blog__card">
          <a href="{{ article.url }}" class="main-blog__card-link">
            {% if article.image %}
              <div class="main-blog__card-image">
                <img src="{{ article.image | img_url: '600x400', crop: 'center' }}" alt="{{ article.title }}" loading="lazy">
              </div>
            {% endif %}
            <div class="main-blog__card-content">
              <h2 class="main-blog__card-title">{{ article.title }}</h2>
              <p class="main-blog__card-excerpt">{{ article.excerpt_or_content | strip_html | truncate: 150 }}</p>
              <div class="main-blog__card-meta">
                <span>{{ article.author }}</span>
                <span>{{ article.published_at | date: '%B %d, %Y' }}</span>
              </div>
            </div>
          </a>
        </article>
      {% endfor %}
    </div>
    {% if paginate.pages > 1 %}
      <div class="main-blog__pagination">
        {% render 'pagination', paginate: paginate %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Main blog",
  "settings": [],
  "presets": [
    {
      "name": "Main blog"
    }
  ]
}
{% endschema %}
